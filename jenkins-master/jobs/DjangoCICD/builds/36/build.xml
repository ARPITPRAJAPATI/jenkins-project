    <script>@Library(&quot;Shared&quot;) _
pipeline {
    agent { label &quot;aru&quot; }

    environment {
        IMAGE_NAME = &quot;notes-app&quot;
        IMAGE_TAG  = &quot;latest&quot;
    }

    stages {

        stage(&quot;Hello&quot;) {
            steps {
                script {
                    hello()
                }
            }
        }

        stage(&quot;Clone&quot;) {
            steps {
                script {
                    clone(&quot;https://github.com/ARPITPRAJAPATI/django-notes-app.git&quot;, &quot;dev&quot;)
                }
            }
        }

        stage(&quot;Build&quot;) {
            steps {
                script {
                    docker_build(env.IMAGE_NAME, env.IMAGE_TAG, &quot;aruhehe&quot;)
                }
            }
        }

        stage(&quot;Push to DockerHub&quot;) {
            steps {
                script{
                    docker_push(&quot;notes-app&quot;, &quot;latest&quot;,&quot;aruhehe&quot;)
                }
            }
        }

        stage(&quot;Deploy&quot;) {
            steps {
                echo &quot;Deploying container&quot;
                sh &quot;docker compose up -d&quot;
            }
        }

        stage(&quot;Cleanup&quot;) {
            steps {
                echo &quot;Cleaning unused Docker resources&quot;
                sh &quot;docker system prune -f&quot;
            }
        }
    }
}</script>
